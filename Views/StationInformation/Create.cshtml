@model GSoftPosNew.Models.TerminalPrinterSetting

@{
    ViewData["Title"] = "Add Station";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --sf-bg: #f4f7fb;
        --sf-card: #ffffff;
        --sf-line: #e2e8f0;
        --sf-text: #0f172a;
        --sf-muted: #64748b;
        --sf-primary: #2563eb;
        --sf-primary-2: #7c3aed;
        --sf-shadow: 0 18px 40px rgba(15, 23, 42, .08);
    }

    .station-form-shell {
        max-width: 980px;
        margin: 0 auto;
    }

    .station-form-hero {
        background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
        border-radius: 24px;
        padding: 22px 24px;
        color: #fff;
        margin-bottom: 18px;
        box-shadow: 0 18px 45px rgba(37, 99, 235, .22);
    }

        .station-form-hero h1 {
            margin: 0 0 6px 0;
            font-size: 1.6rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 12px;
        }

    .station-form-card {
        background: #fff;
        border: 1px solid var(--sf-line);
        border-radius: 24px;
        box-shadow: var(--sf-shadow);
        overflow: hidden;
    }

    .station-form-head {
        padding: 18px 22px;
        border-bottom: 1px solid var(--sf-line);
        background: linear-gradient(180deg,#ffffff,#f8fafc);
    }

        .station-form-head h3 {
            margin: 0;
            font-size: 1.08rem;
            font-weight: 800;
            color: var(--sf-text);
            display: flex;
            align-items: center;
            gap: 10px;
        }

    .station-form-body {
        padding: 22px;
    }

    .station-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0,1fr));
        gap: 18px;
    }

    .station-form-group {
        background: #fbfdff;
        border: 1px solid var(--sf-line);
        border-radius: 18px;
        padding: 16px;
    }

        .station-form-group.full {
            grid-column: 1 / -1;
        }

    .station-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 800;
        color: var(--sf-text);
    }

        .station-label i {
            color: var(--sf-primary);
            margin-right: 6px;
        }

    .station-input {
        width: 100%;
        height: 48px;
        border: 1px solid #dbe2ea;
        border-radius: 14px;
        padding: 0 14px;
        background: #fff;
        color: var(--sf-text);
        outline: none;
        transition: .18s ease;
    }

        .station-input:focus {
            border-color: #93c5fd;
            box-shadow: 0 0 0 4px rgba(37,99,235,.08);
        }

    .station-help {
        color: var(--sf-muted);
        font-size: .85rem;
        margin-top: 8px;
        font-weight: 600;
    }

    .station-check {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #f8fafc;
        border: 1px dashed var(--sf-line);
        border-radius: 16px;
        padding: 14px 16px;
        font-weight: 700;
        color: var(--sf-text);
    }

    .station-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 22px;
        flex-wrap: wrap;
    }

    .station-btn {
        border: none;
        border-radius: 14px;
        padding: 11px 18px;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        transition: .18s ease;
    }

        .station-btn:hover {
            transform: translateY(-1px);
        }

    .station-btn-primary {
        background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
        color: #fff;
        box-shadow: 0 12px 26px rgba(37, 99, 235, .22);
    }

        .station-btn-primary:hover {
            color: #fff;
        }

    .station-btn-secondary {
        background: #f8fafc;
        color: #334155;
        border: 1px solid #cbd5e1;
    }

    .text-danger.small {
        display: block;
        margin-top: 6px;
    }

    @@media (max-width: 768px) {
        .station-form-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="station-form-shell">
    <div class="station-form-hero">
        <h1><i class="fa fa-plus-circle"></i> Add Station</h1>
        <p class="mb-0">Create a new station and assign its PC name and printer path for direct mapped printing.</p>
    </div>

    <div class="station-form-card">
        <div class="station-form-head">
            <h3><i class="fa fa-sliders-h"></i> Station Setup Information</h3>
        </div>

        <div class="station-form-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="station-form-grid">
                    <div class="station-form-group">
                        <label asp-for="StationName" class="station-label">
                            <i class="fa fa-desktop"></i> Station Name
                        </label>
                        <input asp-for="StationName" class="station-input" placeholder="Example: SERVER or COUNTER1" />
                        <span asp-validation-for="StationName" class="text-danger small"></span>
                        <div class="station-help">Use a simple unique station name.</div>
                    </div>

                    <div class="station-form-group">
                        <label asp-for="PCName" class="station-label">
                            <i class="fa fa-laptop"></i> PC Name
                        </label>
                        <input asp-for="PCName" class="station-input" placeholder="Example: SERVER-PC" />
                        <span asp-validation-for="PCName" class="text-danger small"></span>
                        <div class="station-help">Write the computer/device name here.</div>
                    </div>

                    <div class="station-form-group full">
                        <label asp-for="ReceiptPrinterPath" class="station-label">
                            <i class="fa fa-print"></i> Receipt Printer Path
                        </label>
                        <input asp-for="ReceiptPrinterPath" class="station-input" placeholder="Example: DEFAULT or \\COUNTER1-PC\POSCLIENT1" />
                        <span asp-validation-for="ReceiptPrinterPath" class="text-danger small"></span>
                        <div class="station-help">
                            For server printer use <strong>DEFAULT</strong>. For network shared printer use full shared path.
                        </div>
                    </div>

                    <div class="station-form-group full">
                        <div class="station-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label mb-0">
                                Keep this station active for printing
                            </label>
                        </div>
                    </div>
                </div>

                <div class="station-actions">
                    <a asp-action="Index" class="station-btn station-btn-secondary">
                        <i class="fa fa-arrow-left"></i> Back
                    </a>
                    <button type="submit" class="station-btn station-btn-primary">
                        <i class="fa fa-save"></i> Save Station
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}