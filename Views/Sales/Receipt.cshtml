@using GSoftPosNew.ViewModels
@model SaleReceiptViewModel
@{
    Layout = null;
    bool isReturn = Model.InvoiceNumber.Contains("RETURN") || Model.InvoiceNumber.Contains("R-") || Model.Total < 0;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Receipt</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --line: #111;
            --line2: #d7d7d7;
            --text: #000;
            --soft: #f5f5f5;
            --fs: 1.32;
        }

        html, body {
            background: #fff;
            color: #000;
            font-family: Arial, Helvetica, sans-serif;
            line-height: 1.15;
        }

        body {
            width: 80mm;
            max-width: 80mm;
            margin: 0 auto;
            padding: 1.5mm 1.8mm;
            font-size: calc(10px * var(--fs));
        }

        @@page {
            size: 80mm auto;
            margin: 0;
            padding: 0;
        }

        @@media print {
            body {
                margin: 0;
                padding: 1mm 1.5mm;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            .no-print {
                display: none !important;
            }
        }

        .receipt-container {
            width: 100%;
            padding: 0;
        }

        /* HEADER */
        .header {
            text-align: center;
            padding: 0 0 7px 0;
            border-bottom: 1px solid var(--line);
            margin-bottom: 7px;
        }

        .logo-wrap {
            width: 100%;
            min-height: 82px;
            max-height: 110px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 2px auto 5px auto;
            padding: 2px 0;
            overflow: hidden;
        }

        .logo {
            display: block;
            max-width: 100%;
            width: auto;
            height: auto;
            max-height: 95px;
            object-fit: contain;
            image-rendering: auto;
        }

        .shop-title {
            font-size: calc(15px * var(--fs));
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: var(--text);
            line-height: 1.1;
            margin: 2px 0 4px 0;
            word-break: break-word;
        }

        .shop-details {
            font-size: calc(9.8px * var(--fs));
            line-height: 1.35;
            color: #000;
            font-weight: 800;
            word-break: break-word;
        }

            .shop-details div {
                margin: 1px 0;
            }

        .return-badge {
            display: inline-block;
            margin-top: 5px;
            background: #d92323;
            color: #fff;
            border-radius: 4px;
            padding: 3px 8px;
            font-weight: 900;
            font-size: calc(9.8px * var(--fs));
            letter-spacing: .4px;
        }

        /* INFO BLOCKS */
        .info-block {
            margin: 7px 0;
            padding: 4px 0 3px 0;
            border-bottom: 1px solid var(--line);
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 8px;
            margin: 3px 0;
            padding: 1px 0;
            font-size: calc(10px * var(--fs));
        }

            .detail-row .label {
                font-weight: 900;
                white-space: nowrap;
                color: #000;
            }

            .detail-row .value {
                font-weight: 800;
                color: #000;
                text-align: right;
                word-break: break-word;
                flex: 1;
            }

        /* ITEMS HEADER */
        .items-header-line {
            display: flex;
            align-items: center;
            font-weight: 900;
            font-size: calc(10px * var(--fs));
            border-top: none;
            border-bottom: 1px solid var(--line);
            padding: 4px 0;
            margin: 5px 0 4px 0;
            color: #000;
        }

            .items-header-line .h-sr {
                width: 22px;
                text-align: left;
            }

            .items-header-line .h-title {
                flex: 1;
                text-align: center;
            }

            .items-header-line .h-amt {
                width: 76px;
                text-align: right;
                padding-right: 2px;
            }

        /* ITEMS */
        .item-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 4px;
            padding: 4px 0;
            border-bottom: 1px solid var(--line2);
            font-size: calc(10px * var(--fs));
        }

            .item-row:last-child {
                border-bottom: none;
            }

        .item-left {
            display: flex;
            align-items: flex-start;
            flex: 1;
            min-width: 0;
        }

        .srbox {
            width: 22px;
            flex-shrink: 0;
            font-weight: 900;
            font-size: calc(10px * var(--fs));
            color: #000;
            padding-top: 1px;
        }

        .item-details {
            flex: 1;
            min-width: 0;
            padding-left: 4px;
        }

        .item-name {
            display: block;
            font-weight: 900;
            font-size: calc(10px * var(--fs));
            line-height: 1.2;
            color: #000;
            word-break: break-word;
            margin-bottom: 2px;
        }

        .item-meta {
            font-size: calc(8.9px * var(--fs));
            line-height: 1.25;
            color: #000;
            font-weight: 800;
        }

        .qty-price {
            display: inline-block;
            background: var(--soft);
            border: 1px solid #cfcfcf;
            border-radius: 3px;
            padding: 2px 4px;
            font-weight: 900;
            color: #000;
        }

        .disc-badge {
            color: #a30000;
            font-weight: 900;
            margin-left: 5px;
        }

        .tax-badge {
            color: #0b6b0b;
            font-weight: 900;
            margin-left: 5px;
        }

        .item-amount {
            width: 76px;
            flex-shrink: 0;
            text-align: right;
            font-weight: 900;
            font-size: calc(10px * var(--fs));
            line-height: 1.2;
            color: #000;
            padding-top: 1px;
        }

        /* TOTALS */
        .totals {
            margin: 8px 0;
            padding-top: 3px;
            color: #000;
        }

        .total-line {
            display: flex;
            justify-content: space-between;
            gap: 8px;
            margin: 4px 0;
            padding: 1px 0;
            font-size: calc(11px * var(--fs));
            color: #000;
        }

            .total-line span:first-child,
            .total-line span:last-child {
                font-weight: 900;
            }

        .grand-total {
            border-top: 1px solid var(--line);
            margin-top: 5px;
            padding-top: 5px;
            font-size: calc(13px * var(--fs));
            font-weight: 900;
        }

        /* PAYMENT */
        .payment-section {
            background: #f5f5f5;
            border: 1px solid #d3d3d3;
            border-radius: 4px;
            padding: 6px 6px;
            margin: 8px 0;
            color: #000;
        }

        .payment-row {
            display: flex;
            justify-content: space-between;
            gap: 8px;
            margin: 3px 0;
            padding: 1px 0;
            font-size: calc(10.5px * var(--fs));
            color: #000;
        }

            .payment-row span:first-child,
            .payment-row span:last-child {
                font-weight: 900;
            }

        /* FOOTER NOTE AT VERY END */
        .end-note {
            margin-top: 8px;
            padding-top: 5px;
            border-top: 1px solid var(--line);
            text-align: center;
        }

        .dynamic-message {
            font-size: calc(8.2px * var(--fs));
            line-height: 1.28;
            color: #000;
            font-weight: 800;
            margin-bottom: 4px;
            word-break: break-word;
        }

        .developer-line {
            font-size: calc(8.2px * var(--fs));
            line-height: 1.25;
            color: #000;
            font-weight: 900;
            word-break: break-word;
        }

        .text-red {
            color: #a40000;
            font-weight: 900;
        }

        .print-btn {
            background: #1d4ed8;
            color: #fff;
            border: none;
            padding: 10px 24px;
            border-radius: 6px;
            cursor: pointer;
            margin: 14px auto;
            display: block;
            font-weight: 700;
            font-size: calc(12px * var(--fs));
        }
    </style>
</head>

<body>
    <button class="print-btn no-print" onclick="printReceipt()">🖨 PRINT RECEIPT</button>

    <div class="receipt-container">

        <!-- HEADER -->
        <div class="header">
            <div class="logo-wrap">
                <img src="@(!string.IsNullOrEmpty(ViewBag.Setting?.LogoPath)
                                                                       ? Url.Content(ViewBag.Setting.LogoPath)
                                                                       : "data:image/svg+xml;base64,")"
                     alt="Logo"
                     class="logo" />
            </div>

            <div class="shop-title">@(ViewBag.Setting?.ShopName ?? "G-SOFT SYSTEMS")</div>

            <div class="shop-details">
                @if (!string.IsNullOrWhiteSpace(ViewBag.Setting?.Address))
                {
                    <div>@ViewBag.Setting.Address</div>
                }

                @if (!string.IsNullOrWhiteSpace(ViewBag.Setting?.Contact1) || !string.IsNullOrWhiteSpace(ViewBag.Setting?.Contact2))
                {
                    <div>📞 @ViewBag.Setting?.Contact1 / @ViewBag.Setting?.Contact2</div>
                }
            </div>

            @if (isReturn)
            {
                <div class="return-badge">RETURN INVOICE</div>
            }
        </div>

        <!-- INVOICE INFO -->
        <div class="info-block">
            <div class="detail-row">
                <span class="label">Invoice #:</span>
                <span class="value">@Model.InvoiceNumber</span>
            </div>

            @if (Model.OrderType != null)
            {
                <div class="detail-row">
                    <span class="label">Order Type:</span>
                    <span class="value">@Model.OrderType</span>
                </div>
            }

            <div class="detail-row">
                <span class="label">Date:</span>
                <span class="value">@Model.SaleDate.ToString("dd/MM/yyyy hh:mm tt")</span>
            </div>

            <div class="detail-row">
                <span class="label">Cashier:</span>
                <span class="value">@Model.CashierName</span>
            </div>
        </div>

        <!-- CUSTOMER INFO -->
        <div class="info-block">
            <div class="detail-row">
                <span class="label">Customer:</span>
                <span class="value">@Model.CustomerName</span>
            </div>

            @if (Model.CustomerPhone != null)
            {
                <div class="detail-row">
                    <span class="label">Phone:</span>
                    <span class="value">@Model.CustomerPhone</span>
                </div>
            }

            @if (Model.CustomerAddress != null)
            {
                <div class="detail-row">
                    <span class="label">Address:</span>
                    <span class="value">@Model.CustomerAddress</span>
                </div>
            }
        </div>

        <!-- ITEMS HEADER -->
        <div class="items-header-line">
            <div class="h-sr">#</div>
            <div class="h-title">ITEMS</div>
            <div class="h-amt">AMOUNT</div>
        </div>

        <!-- ITEMS -->
        @if (Model.Items != null && Model.Items.Any())
        {
            var srNo = 1;
            foreach (var item in Model.Items)
            {
                <div class="item-row">
                    <div class="item-left">
                        <div class="srbox">@srNo</div>

                        <div class="item-details">
                            <span class="item-name">@item.ItemName</span>

                            <div class="item-meta">
                                <span class="qty-price">
                                    @item.Quantity.ToString("0.##") x @item.UnitPrice.ToString("N0")
                                </span>

                                @if (item.DiscountPercent > 0)
                                {
                                    <span class="disc-badge">@item.DiscountPercent% Disc</span>
                                }

                                @if (item.TaxAmount > 0)
                                {
                                    <span class="tax-badge">@item.TaxAmount.ToString("N0") Tax</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="item-amount">@item.LineTotal.ToString("N0")</div>
                </div>
                srNo++;
            }
        }
        else
        {
            <div class="item-row">
                <div class="item-left">
                    <div class="srbox">&nbsp;</div>
                    <div class="item-details">
                        <span class="item-name">No items in this sale</span>
                    </div>
                </div>
                <div class="item-amount">0</div>
            </div>
        }

        <!-- TOTALS -->
        <div class="totals">
            <div class="total-line">
                <span>Sub Total:</span>
                <span>@Model.SubTotal.ToString("N0")</span>
            </div>

            @if (Model.ServiceCharges != null && Model.ServiceCharges > 0)
            {
                <div class="total-line">
                    <span>Service Charges:</span>
                    <span>+@Model.ServiceCharges?.ToString("N0")</span>
                </div>
            }

            @if (Model.Tax > 0)
            {
                <div class="total-line">
                    <span>Tax Amount:</span>
                    <span>+@Model.Tax.ToString("N0")</span>
                </div>
            }

            @if (Model.Discount > 0)
            {
                <div class="total-line">
                    <span>Total Discount:</span>
                    <span>-@Model.Discount.ToString("N0")</span>
                </div>
            }

            <div class="total-line grand-total @(isReturn ? "text-red" : "")">
                <span>@(isReturn ? "RETURN AMOUNT:" : "GRAND TOTAL:")</span>
                <span>@(isReturn ? "-" : "")@Math.Abs(Model.Total).ToString("N0")</span>
            </div>
        </div>

        <!-- PAYMENT -->
        <div class="payment-section">
            <div class="payment-row">
                <span>Payment:</span>
                <span>@Model.PaymentMethod</span>
            </div>

            <div class="payment-row">
                <span>@(isReturn ? "Refund Amount:" : "Amount Paid:")</span>
                <span>@Math.Abs(Model.PaidAmount).ToString("N0")</span>
            </div>

            @if (Model.Change > 0)
            {
                <div class="payment-row">
                    <span>@(isReturn ? "Balance:" : "Change:")</span>
                    <span>@Math.Abs(Model.Change).ToString("N0")</span>
                </div>
            }
        </div>

        <!-- LAST END NOTE -->
        <div class="end-note">
            @if (!string.IsNullOrWhiteSpace(ViewBag.Setting?.Message))
            {
                <div class="dynamic-message">
                    @Html.Raw((ViewBag.Setting.Message ?? "").Replace("\r\n", "<br />").Replace("\n", "<br />"))
                </div>
            }

            <div class="developer-line">
                Software developed by G-Soft Systems
            </div>
        </div>

    </div>

    <script>
        function autoPrint() {
            setTimeout(() => { window.print(); }, 400);
        }

        function printReceipt() {
            window.print();
        }

        window.onafterprint = function () {
            setTimeout(() => { window.close(); }, 400);
        };

        document.addEventListener('DOMContentLoaded', autoPrint);
    </script>
</body>
</html>