@using GSoftPosNew.ViewModels
@model SaleReceiptViewModel
@{
    Layout = null;
    bool isReturn = (Model?.InvoiceNumber ?? "").Contains("RETURN") || (Model?.InvoiceNumber ?? "").Contains("R-") || (Model?.Total ?? 0) < 0;
    var customerName = string.IsNullOrWhiteSpace(Model?.CustomerName) ? "Walk-in Customer" : Model.CustomerName;
    var customerPhone = string.IsNullOrWhiteSpace(Model?.CustomerPhone) ? "" : Model.CustomerPhone;
    var customerAddress = string.IsNullOrWhiteSpace(Model?.CustomerAddress) ? "" : Model.CustomerAddress;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Receipt</title>
    <style>
        * { box-sizing: border-box; }
        html, body {
            margin: 0;
            padding: 0;
            background: #fff;
            color: #000;
            font-family: "Courier New", monospace;
            font-weight: 700;
        }

        body {
            width: 80mm;
            margin: 0 auto;
            padding: 4px;
            font-size: 13px; /* overall bigger + darker */
        }

        #receiptContent {
            width: 100%;
        }

        .text-center { text-align: center; }
        .mb-1 { margin-bottom: 4px; }
        .mb-2 { margin-bottom: 8px; }
        .mt-1 { margin-top: 4px; }
        .mt-2 { margin-top: 8px; }
        .pt-1 { padding-top: 4px; }
        .rounded { border-radius: 6px; }

        .logo {
            width: 72px;
            height: 72px;
            margin: 0 auto 8px auto;
            display: block;
            object-fit: cover;
            border: 1px solid #d1d5db;
            border-radius: 50%;
            padding: 2px;
        }

        .shop-name {
            font-size: 18px;
            font-weight: 700;
            letter-spacing: .3px;
        }

        .shop-line {
            font-size: 14px;
            line-height: 1.35;
            font-weight: 700;
        }

        .section {
            border-top: 1px dashed #444;
            padding-top: 5px;
            margin-top: 5px;
        }

        .row {
            display: flex;
            justify-content: space-between;
            gap: 8px;
            font-size: 13px;
            margin: 2px 0;
            font-weight: 700;
        }

        .row .label {
            font-weight: 700;
            white-space: nowrap;
        }

        .row .value {
            text-align: right;
            flex: 1;
            word-break: break-word;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
            font-weight: 700;
        }

        thead tr {
            border-bottom: 1px solid #cfcfcf;
        }

        th, td {
            padding: 3px 0;
            vertical-align: top;
        }

        th {
            text-align: left;
            font-size: 13px;
            font-weight: 700;
        }

        .num, .amt {
            text-align: right;
        }

        .item-name {
            word-break: break-word;
        }

        .muted {
            color: #444;
        }

        .totals-table td {
            padding: 2px 0;
            font-size: 14px;
            font-weight: 700;
        }

        .grand-total td {
            border-top: 1px solid #000;
            font-size: 16px;
            font-weight: 800;
            padding-top: 4px;
        }

        .footer {
            text-align: center;
            font-size: 13px;
            font-weight: 700;
        }

        .return-badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 4px;
            background: #dc2626;
            color: #fff;
            font-weight: 700;
            margin-top: 5px;
            font-size: 12px;
        }

        .print-btn {
            display: none;
        }

        @@page {
            size: 80mm auto;
            margin: 0;
        }

        @@media print {
            body {
                width: 80mm;
                padding: 4px;
            }

            .print-btn {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <div class="text-center mb-2">
        <button id="printBtn" onclick="printReceipt()" class="print-btn">🖨 Print</button>
    </div>

    <div id="receiptContent">
        <div class="text-center mb-2">
            <img src="@(!string.IsNullOrEmpty(ViewBag.Setting?.LogoPath)
                         ? Url.Content(ViewBag.Setting.LogoPath)
                         : Url.Content("~/images/gsoftLogo.jpeg"))"
                 alt="Shop Logo"
                 class="logo" />

            <div class="shop-name">@(@ViewBag.Setting?.ShopName ?? "G-Soft")</div>

            @if (!string.IsNullOrWhiteSpace(ViewBag.Setting?.Address))
            {
                <div class="shop-line">@ViewBag.Setting.Address</div>
            }

            @if (!string.IsNullOrWhiteSpace(ViewBag.Setting?.Contact1) || !string.IsNullOrWhiteSpace(ViewBag.Setting?.Contact2))
            {
                <div class="shop-line">Phone: @ViewBag.Setting?.Contact1 @(!string.IsNullOrWhiteSpace(ViewBag.Setting?.Contact1) && !string.IsNullOrWhiteSpace(ViewBag.Setting?.Contact2) ? "," : "") @ViewBag.Setting?.Contact2</div>
            }

            @if (isReturn)
            {
                <div class="return-badge">RETURN INVOICE</div>
            }
        </div>

        <div class="section">
            <div class="row">
                <div class="label">Invoice #:</div>
                <div class="value">@Model.InvoiceNumber</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model?.OrderType))
            {
                <div class="row">
                    <div class="label">Order Type:</div>
                    <div class="value">@Model.OrderType</div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model?.TableNo))
            {
                <div class="row">
                    <div class="label">Table #:</div>
                    <div class="value">@Model.TableNo</div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model?.Waiter))
            {
                <div class="row">
                    <div class="label">Waiter:</div>
                    <div class="value">@Model.Waiter</div>
                </div>
            }

            <div class="row">
                <div class="label">Date:</div>
                <div class="value">@Model.SaleDate.ToString("dd MMM yyyy hh:mm tt")</div>
            </div>

            <div class="row">
                <div class="label">Cashier:</div>
                <div class="value">@Model.CashierName</div>
            </div>
        </div>

        <div class="section">
            <div class="row">
                <div class="label">Customer:</div>
                <div class="value">@customerName</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(customerPhone))
            {
                <div class="row">
                    <div class="label">Phone:</div>
                    <div class="value">@customerPhone</div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(customerAddress))
            {
                <div class="row">
                    <div class="label">Address:</div>
                    <div class="value">@customerAddress</div>
                </div>
            }
        </div>

        <div class="section">
            <table>
                <thead>
                    <tr>
                        <th style="width: 18px;">#</th>
                        <th>Item</th>
                        <th class="amt" style="width: 55px;">Price</th>
                        <th class="amt" style="width: 38px;">Qty</th>
                        <th class="amt" style="width: 60px;">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.SrNo</td>
                                <td class="item-name">
                                    <div>@item.ItemName</div>
                                </td>
                                <td class="amt">@item.UnitPrice.ToString("N0")</td>
                                <td class="amt">@item.Quantity.ToString("0.##")</td>
                                <td class="amt">@item.LineTotal.ToString("N0")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center muted">No items found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="section">
            <table class="totals-table">
                <tr>
                    <td class="amt" style="padding-right:8px;">SubTotal:</td>
                    <td class="amt" style="width:80px;">@Model.SubTotal.ToString("N0")</td>
                </tr>

                @if (Model.ServiceCharges != null && Model.ServiceCharges > 0)
                {
                    <tr>
                        <td class="amt" style="padding-right:8px;">Service:</td>
                        <td class="amt">+@Model.ServiceCharges?.ToString("N0")</td>
                    </tr>
                }

                @if (Model.Tax > 0)
                {
                    <tr>
                        <td class="amt" style="padding-right:8px;">Tax:</td>
                        <td class="amt">+@Model.Tax.ToString("N0")</td>
                    </tr>
                }

                @if (Model.Discount > 0)
                {
                    <tr>
                        <td class="amt" style="padding-right:8px;">Discount:</td>
                        <td class="amt">-@Model.Discount.ToString("N0")</td>
                    </tr>
                }

                <tr class="grand-total">
                    <td class="amt" style="padding-right:8px;">@(isReturn ? "RETURN TOTAL:" : "TOTAL:")</td>
                    <td class="amt">@(isReturn ? "-" : "")@Math.Abs(Model.Total).ToString("N0")</td>
                </tr>
            </table>
        </div>

        <div class="section">
            <div class="row">
                <div class="label">Payment:</div>
                <div class="value">@Model.PaymentMethod</div>
            </div>

            <div class="row">
                <div class="label">Amount Paid:</div>
                <div class="value">@Math.Abs(Model.PaidAmount).ToString("N0")</div>
            </div>

            @if (Model.Change > 0)
            {
                <div class="row">
                    <div class="label">Change:</div>
                    <div class="value">@Math.Abs(Model.Change).ToString("N0")</div>
                </div>
            }
        </div>

        <div class="section footer">
            @if (!string.IsNullOrWhiteSpace(ViewBag.Setting?.Message))
            {
                <div class="mb-1">@ViewBag.Setting.Message</div>
            }

            <div>Powered by <b>G-Soft Systems</b></div>
        </div>
    </div>

    <script>
        function printReceipt() {
            window.print();
        }

        function isPreviewMode() {
            const params = new URLSearchParams(window.location.search);
            return params.get('preview') === '1';
        }

        window.onload = function () {
            if (!isPreviewMode()) {
                window.print();
            }
        };

        window.onafterprint = function () {
            if (!isPreviewMode()) {
                window.close();
            }
        };
    </script>
</body>
</html>
