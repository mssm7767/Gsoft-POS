@{
    var role = Context.Items["UserRole"] as string;
    var permissions = Context.Items["UserPermissions"] as Dictionary<string, bool> ?? new();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - GSoft POS</title>

    <!-- Bootstrap & Font Awesome -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/lib/fontawesome/css/all.min.css" rel="stylesheet" />

    <!-- Modern Sidebar Styles -->
    <style>
        /* Modern Color Variables */
        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --primary-light: #e6e9ff;
            --secondary: #764ba2;
            --success: #48bb78;
            --warning: #ed8936;
            --danger: #f56565;
            --dark: #1a202c;
            --darker: #0f172a;
            --light: #f7fafc;
            --gray: #a0aec0;
            --sidebar-bg: linear-gradient(180deg, #1a202c 0%, #2d3748 100%);
            --sidebar-hover: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
            --sidebar-active: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
            --shadow-lg: 0 30px 35px -10px rgba(0, 0, 0, 0.15);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            min-height: 100%;
            font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            overflow-x: hidden;
            background: #f0f5fa;
        }

        /* Modern Sidebar */
        .sidebar {
            width: 280px;
            background: var(--sidebar-bg);
            backdrop-filter: blur(10px);
            transition: var(--transition);
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            overflow-y: auto;
            overflow-x: hidden;
            z-index: 1040;
            box-shadow: 10px 0 30px rgba(0, 0, 0, 0.15);
            border-right: 1px solid rgba(255, 255, 255, 0.05);
        }

            /* Custom Scrollbar */
            .sidebar::-webkit-scrollbar {
                width: 5px;
            }

            .sidebar::-webkit-scrollbar-track {
                background: rgba(255, 255, 255, 0.05);
            }

            .sidebar::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.2);
                border-radius: 10px;
            }

                .sidebar::-webkit-scrollbar-thumb:hover {
                    background: rgba(255, 255, 255, 0.3);
                }

        /* Main Content */
        .main-content {
            margin-left: 280px;
            transition: var(--transition);
            min-height: 100vh;
            padding: 25px !important;
            background: #f0f5fa;
        }

        /* Collapsed States */
        .sidebar.collapsed {
            width: 80px !important;
        }

        .main-content.collapsed {
            margin-left: 80px !important;
        }

        .sidebar.collapsed .sidebar-menu span,
        .sidebar.collapsed .sidebar-bottom span,
        .sidebar.collapsed .logo-text,
        .sidebar.collapsed .arrow-icon {
            display: none;
        }

        .sidebar.collapsed .logo {
            justify-content: center;
            padding: 20px 0;
        }

        .sidebar.collapsed .sidebar-menu a,
        .sidebar.collapsed .sidebar-bottom a {
            justify-content: center;
            padding: 15px 0;
        }

        .sidebar.collapsed .sidebar-menu i,
        .sidebar.collapsed .sidebar-bottom i {
            margin: 0;
            font-size: 22px;
        }

        .sidebar.collapsed .has-sub > a::after {
            display: none;
        }

        /* Logo Section */
        .logo {
            padding: 25px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(0, 0, 0, 0.2);
        }

        .logo-text {
            font-size: 22px;
            font-weight: 800;
            background: linear-gradient(135deg, #fff, #e0e0ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 0.5px;
        }

        /* Toggle Button */
        .sidebar-toggle {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            color: white;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition);
            font-size: 18px;
        }

            .sidebar-toggle:hover {
                background: var(--sidebar-active);
                transform: scale(1.05);
                border-color: transparent;
            }

        /* Sidebar Menu */
        .sidebar-menu {
            list-style: none;
            padding: 20px 15px;
            margin: 0;
        }

            .sidebar-menu li {
                margin-bottom: 5px;
            }

            .sidebar-menu a {
                display: flex;
                align-items: center;
                padding: 12px 15px;
                color: rgba(255, 255, 255, 0.7);
                text-decoration: none;
                border-radius: 16px;
                transition: var(--transition);
                font-weight: 500;
                font-size: 14px;
                position: relative;
                overflow: hidden;
            }

                .sidebar-menu a::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 0;
                    height: 100%;
                    width: 3px;
                    background: linear-gradient(180deg, var(--primary), var(--secondary));
                    border-radius: 0 3px 3px 0;
                    transform: scaleY(0);
                    transition: transform 0.2s;
                }

                .sidebar-menu a:hover {
                    background: var(--sidebar-hover);
                    color: white;
                    transform: translateX(5px);
                }

                    .sidebar-menu a:hover::before {
                        transform: scaleY(1);
                    }

                .sidebar-menu a.active {
                    background: var(--sidebar-active);
                    color: white;
                    box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
                }

                    .sidebar-menu a.active::before {
                        transform: scaleY(1);
                        background: white;
                    }

            .sidebar-menu i {
                width: 30px;
                font-size: 18px;
                text-align: center;
                margin-right: 12px;
            }

        /* Submenu */
        .has-sub {
            position: relative;
        }

            .has-sub > a {
                position: relative;
            }

                .has-sub > a::after {
                    content: '\f107';
                    font-family: 'Font Awesome 6 Free';
                    font-weight: 900;
                    position: absolute;
                    right: 15px;
                    top: 50%;
                    transform: translateY(-50%);
                    transition: var(--transition);
                    font-size: 14px;
                    color: rgba(255, 255, 255, 0.5);
                }

            .has-sub.open > a::after {
                transform: translateY(-50%) rotate(180deg);
            }

            .has-sub.open > a {
                background: var(--sidebar-hover);
                color: white;
            }

        .submenu {
            list-style: none;
            padding-left: 45px;
            margin: 5px 0 10px 0;
            display: none;
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .has-sub.open .submenu {
            display: block;
        }

        .submenu a {
            padding: 10px 15px;
            font-size: 13px;
            background: rgba(255, 255, 255, 0.02);
            margin-bottom: 3px;
        }

            .submenu a:hover {
                background: rgba(255, 255, 255, 0.05);
                transform: translateX(3px);
            }

        .submenu i {
            font-size: 14px;
            width: 25px;
        }

        /* Sidebar Bottom */
        .sidebar-bottom {
            padding: 20px 15px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin-top: auto;
        }

            .sidebar-bottom a {
                display: flex;
                align-items: center;
                padding: 12px 15px;
                color: rgba(255, 255, 255, 0.7);
                text-decoration: none;
                border-radius: 16px;
                transition: var(--transition);
                margin-bottom: 5px;
                font-weight: 500;
            }

                .sidebar-bottom a:hover {
                    background: var(--sidebar-hover);
                    color: white;
                    transform: translateX(5px);
                }

            .sidebar-bottom i {
                width: 30px;
                font-size: 18px;
                margin-right: 12px;
            }

            .sidebar-bottom .text-danger {
                color: #fc8181 !important;
            }

                .sidebar-bottom .text-danger:hover {
                    background: linear-gradient(135deg, #f56565, #c53030);
                    color: white !important;
                }

        /* End of Day Button */
        .eod-button {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border: none;
            border-radius: 16px;
            padding: 15px 20px;
            margin: 15px;
            color: white;
            font-weight: 700;
            font-size: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            cursor: pointer;
            transition: var(--transition);
            width: calc(100% - 30px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

            .eod-button:hover {
                transform: translateY(-3px);
                box-shadow: 0 15px 30px rgba(102, 126, 234, 0.4);
            }

            .eod-button i {
                font-size: 18px;
                margin: 0;
            }

        .sidebar.collapsed .eod-button span {
            display: none;
        }

        .sidebar.collapsed .eod-button {
            padding: 15px 0;
            justify-content: center;
        }

        /* Mobile Overlay */
        .mobile-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            z-index: 1030;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

            .mobile-overlay.show {
                display: block;
                opacity: 1;
            }

        /* Responsive */
        @@media (max-width: 991.98px) {
            .sidebar {
                left: -300px;
                width: 280px !important;
                box-shadow: 10px 0 30px rgba(0,0,0,0.3);
            }

                .sidebar.mobile-open {
                    left: 0;
                }

            .main-content,
            .main-content.collapsed {
                margin-left: 0 !important;
                padding: 15px !important;
            }

            .sidebar.collapsed {
                width: 280px !important;
            }

                .sidebar.collapsed .sidebar-menu span,
                .sidebar.collapsed .sidebar-bottom span,
                .sidebar.collapsed .logo-text,
                .sidebar.collapsed .arrow-icon {
                    display: inline;
                }

                .sidebar.collapsed .logo {
                    justify-content: space-between;
                    padding: 25px 20px;
                }

                .sidebar.collapsed .sidebar-menu a,
                .sidebar.collapsed .sidebar-bottom a {
                    justify-content: flex-start;
                    padding: 12px 15px;
                }

                .sidebar.collapsed .sidebar-menu i,
                .sidebar.collapsed .sidebar-bottom i {
                    margin-right: 12px;
                    font-size: 18px;
                }

                .sidebar.collapsed .eod-button span {
                    display: inline;
                }

                .sidebar.collapsed .eod-button {
                    padding: 15px 20px;
                    justify-content: center;
                }

            .mobile-overlay.show {
                display: block;
            }
        }

        /* Animations */
        @@keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.05);
            }
        }

        .pulse {
            animation: pulse 2s infinite;
        }

        /* Tooltip for collapsed mode */
        .sidebar.collapsed [data-tooltip] {
            position: relative;
        }

            .sidebar.collapsed [data-tooltip]:hover::after {
                content: attr(data-tooltip);
                position: absolute;
                left: 100%;
                top: 50%;
                transform: translateY(-50%);
                background: var(--dark);
                color: white;
                padding: 8px 12px;
                border-radius: 8px;
                font-size: 12px;
                white-space: nowrap;
                z-index: 1000;
                margin-left: 10px;
                box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            }

        /* Loading animation */
        .loading-bar {
            height: 3px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 9999;
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.3s;
        }

            .loading-bar.active {
                transform: scaleX(1);
            }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Loading Bar -->
    <div class="loading-bar" id="loadingBar"></div>

    <!-- Mobile Overlay -->
    <div class="mobile-overlay" id="mobileOverlay"></div>

    <!-- Modern Sidebar -->
    <div class="sidebar" id="sidebar">
        <div class="logo">
            <span class="logo-text">G-Soft POS</span>
            <button class="sidebar-toggle" id="sidebarToggle" title="Collapse/Expand" type="button">
                <i class="fas fa-bars"></i>
            </button>
        </div>

        <ul class="sidebar-menu">
            @if (permissions.TryGetValue("Dashboard", out var canAccessDashboard) && canAccessDashboard)
            {

                <li>
                    <a asp-controller="Home" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                        <i class="fa fa-th-large"></i> <span>Dashboard</span>
                    </a>
                </li>
            }
            <!-- Add Submenu -->
            <li class="has-sub">
                <a href="#">
                    <i class="fa fa-plus-circle"></i> <span>Add</span>
                    <i class="arrow-icon">
                        <svg class="chevron-svg" width="15" height="15" viewBox="0 0 16 16" fill="none">
                            <path d="M5 7L8 10L11 7"
                                  stroke="currentColor"
                                  stroke-width="1.7"
                                  stroke-linecap="round"
                                  stroke-linejoin="round" />
                        </svg>
                    </i>
                </a>
                <ul class="submenu">
                    @if (permissions.TryGetValue("User", out var canAccessAddUser) && canAccessAddUser)
                    {
                        <li><a asp-controller="User" asp-action="Create"><i class="fa fa-user-plus"></i> Add New User</a></li>
                    }
                    @if (permissions.TryGetValue("AddCustomers", out var canAccessAddCustomers) && canAccessAddCustomers)
                    {
                        <li><a asp-controller="Customer" asp-action="Create"><i class="fa fa-user"></i> Add Customer</a></li>
                    }
                    @if (permissions.TryGetValue("Suppliers", out var canAccessAddSuppliers) && canAccessAddSuppliers)
                    {
                        <li><a asp-controller="Supplier" asp-action="Create"><i class="fa fa-user-tie"></i> Add Supplier</a></li>
                    }
                    @if (permissions.TryGetValue("Categories", out var canAccessAddCategory) && canAccessAddCategory)
                    {
                        <li><a asp-controller="Category" asp-action="Create"><i class="fa fa-tags"></i> Add Category</a></li>
                    }
                    @if (permissions.TryGetValue("SubCategory", out var canAccessAddSubCategory) && canAccessAddSubCategory)
                    {
                        <li><a asp-controller="SubCategory" asp-action="Create"><i class="fa fa-tag"></i> Add Sub Category</a></li>
                    }
                    @if (permissions.TryGetValue("Location", out var canAccessAddLocation) && canAccessAddLocation)
                    {
                        <li><a asp-controller="Location" asp-action="Create"><i class="fa fa-map-marker-alt"></i> Add Location</a></li>
                    }
                    @if (permissions.TryGetValue("AddTable", out var canAccessAddTable) && canAccessAddTable)
                    {

                        <li>
                            <a asp-controller="Table" asp-action="Create">
                                <i class="fa fa-table"></i> Add Table
                            </a>
                        </li>

                    }

                    @if (permissions.TryGetValue("Department", out var canAccessDepartment) && canAccessDepartment)
                    {

                        <li>
                            <a asp-controller="PrinterDepartment" asp-action="Index">
                                <i class="fa fa-print"></i> Department / Printer
                            </a>
                        </li>

                    }

                </ul>

            </li>

            <!-- Items Submenu -->
            @if (permissions.TryGetValue("Items", out var canAccessItems) && canAccessItems)
            {
                <li class="has-sub">
                    <a href="#">
                        <i class="fa fa-box"></i> <span>Items</span>
                        <i class="arrow-icon">
                            <svg class="chevron-svg" width="15" height="15" viewBox="0 0 16 16" fill="none">
                                <path d="M5 7L8 10L11 7"
                                      stroke="currentColor"
                                      stroke-width="1.7"
                                      stroke-linecap="round"
                                      stroke-linejoin="round" />
                            </svg>
                        </i>
                    </a>
                    <ul class="submenu">
                        <li>
                            <a asp-controller="Item" asp-action="Add">
                                <i class="fa fa-plus-circle"></i> New Item
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Item" asp-action="Index">
                                <i class="fa fa-edit"></i> Stock List
                            </a>
                        </li>
                        <li>
                            <a href="@Url.Action("Index", "StockAdjustment")">
                                <i class="fa fa-exchange-alt"></i> Stock Adjustment
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Unit" asp-action="Create">
                                <i class="fa fa-balance-scale"></i> Units
                            </a>
                        </li>

                        <!-- 🔹 NEW MENU ITEM: Ad Category/Ingredient -->
                        <li>
                            <a asp-controller="Ingredient" asp-action="Index">
                                <i class="fa fa-bowl-food"></i> Ingredient Stock
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Ingredient" asp-action="Setup">
                                <i class="fa fa-bowl-food"></i> Ad Category / Ingredient
                            </a>
                        </li>
                    </ul>
                </li>
            }

            <!-- Purchase Submenu -->
            @if (permissions.TryGetValue("Purchase", out var canAccessPurchase) && canAccessPurchase)
            {
                <li class="has-sub">
                    <a href="#">
                        <i class="fa fa-truck"></i> <span>Purchase</span>
                        <i class="arrow-icon">
                            <svg class="chevron-svg" width="15" height="15" viewBox="0 0 16 16" fill="none">
                                <path d="M5 7L8 10L11 7"
                                      stroke="currentColor"
                                      stroke-width="1.7"
                                      stroke-linecap="round"
                                      stroke-linejoin="round" />
                            </svg>
                        </i>
                    </a>
                    <ul class="submenu">
                        <li><a asp-controller="Purchase" asp-action="Create"><i class="fa fa-plus-circle"></i> New Purchase</a></li>
                        <li><a asp-controller="Purchase" asp-action="Index"><i class="fa fa-list"></i> Purchase List</a></li>
                        <li><a asp-controller="Purchase" asp-action="IngredientIndex"><i class="fa fa-list"></i> Ingredient Purchase List</a></li>
                    </ul>
                </li>
            }
            <!-- Sales Submenu -->
            @if (permissions.TryGetValue("Sales", out var canAccessSales) && canAccessSales)
            {

                <li class="has-sub">
                    <a href="#">
                        <i class="fa fa-shopping-cart"></i> <span>Sales</span>
                        <i class="arrow-icon">
                            <svg class="chevron-svg" width="15" height="15" viewBox="0 0 16 16" fill="none">
                                <path d="M5 7L8 10L11 7"
                                      stroke="currentColor"
                                      stroke-width="1.7"
                                      stroke-linecap="round"
                                      stroke-linejoin="round" />
                            </svg>
                        </i>
                    </a>
                    <ul class="submenu">
                        @if (permissions.TryGetValue("POSNew", out var canAccessPOSNew) && canAccessPOSNew)

                        {

                            <li><a asp-controller="Sales" asp-action="POS"><i class="fa fa-plus-circle"></i> POS New</a></li>

                        }
                        @if (permissions.TryGetValue("POSTouch", out var canAccessPOSTouch) && canAccessPOSTouch)

                        {

                            <li><a asp-controller="Sales" asp-action="POSTouch"><i class="fa fa-plus-circle"></i> POS Touch</a></li>

                        }
                        @if (permissions.TryGetValue("SaleList", out var canAccessSaleList) && canAccessSaleList)

                        {

                            <li><a asp-controller="Sales" asp-action="Index"><i class="fa fa-list"></i> Sales List</a></li>

                        }

                        @if (permissions.TryGetValue("SaleReturn", out var canAccessSaleReturn) && canAccessSaleReturn)
                        {

                            <li>
                                <a asp-controller="Sales" asp-action="SalesReturn">
                                    <i class="fa fa-rotate-left"></i> Sales Return
                                </a>
                            </li>

                        }
                    </ul>
                </li>
            }

            <!-- Barcode Submenu -->
            @if (permissions.TryGetValue("Barcode", out var canAccessBarcode) && canAccessBarcode)
            {

                <li class="has-sub">
                    <a href="#">
                        <i class="fa fa-barcode"></i> <span>Barcode</span>
                        <i class="arrow-icon">
                            <svg class="chevron-svg" width="15" height="15" viewBox="0 0 16 16" fill="none">
                                <path d="M5 7L8 10L11 7"
                                      stroke="currentColor"
                                      stroke-width="1.7"
                                      stroke-linecap="round"
                                      stroke-linejoin="round" />
                            </svg>
                        </i>
                    </a>
                    <ul class="submenu">
                        <li><a asp-controller="ItemBarcode" asp-action="Index"><i class="fa fa-print"></i> Item Barcode</a></li>
                        <li><a asp-controller="Barcode" asp-action="Print"><i class="fa fa-print"></i> Print Barcodes</a></li>
                    </ul>
                </li>
            }

            <!-- Customers Submenu -->
            @if (permissions.TryGetValue("Customers", out var canAccessCustomers) && canAccessCustomers)
            {
                <li class="has-sub">
                    <a href="#">
                        <i class="fa fa-users"></i>
                        <span>Customer</span>
                        <i class="arrow-icon">
                            <svg class="chevron-svg" width="15" height="15" viewBox="0 0 16 16" fill="none">
                                <path d="M5 7L8 10L11 7"
                                      stroke="currentColor"
                                      stroke-width="1.7"
                                      stroke-linecap="round"
                                      stroke-linejoin="round" />
                            </svg>
                        </i>
                    </a>
                    <ul class="submenu">
                        @if (permissions.TryGetValue("AddCustomers", out var canAccessAddCustomer) && canAccessAddCustomer)
                        {
                            <li>
                                <a asp-controller="Customer" asp-action="Create">
                                    <i class="fa fa-user-plus"></i> Add Customer
                                </a>
                            </li>
                        }


                        <li>
                            <a asp-controller="Sales" asp-action="CustomerReport">
                                <i class="fa fa-list"></i> Customer Reports
                            </a>
                        </li>
                        @if (permissions.TryGetValue("CustomersPayment", out var canAccessCustomersPayment) && canAccessCustomersPayment)
                        {
                            <li>
                                <a asp-controller="CustomerPayment" asp-action="Receive" target="_blank">
                                    <i class="fa fa-money-bill-wave"></i> C.Pay Receiving
                                </a>
                            </li>
                        }

                    </ul>
                </li>
            }
            <!-- Supplier Submenu -->
            @if (permissions.TryGetValue("Suppliers", out var canAccessSuppliers) && canAccessSuppliers)
            {
                <li class="has-sub">
                    <a href="#">
                        <i class="fa fa-user-tie"></i> <span>Supplier</span>
                        <i class="arrow-icon">
                            <svg class="chevron-svg" width="15" height="15" viewBox="0 0 16 16" fill="none">
                                <path d="M5 7L8 10L11 7"
                                      stroke="currentColor"
                                      stroke-width="1.7"
                                      stroke-linecap="round"
                                      stroke-linejoin="round" />
                            </svg>
                        </i>
                    </a>
                    <ul class="submenu">
                        <li>
                            <a asp-controller="Supplier" asp-action="Create">
                                <i class="fa fa-user-plus"></i> Add Supplier
