    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');
            const sidebarToggle = document.getElementById('sidebarToggle');
            const mobileOverlay = document.getElementById('mobileOverlay');
            const loadingBar = document.getElementById('loadingBar');

            // Loading bar animation
            window.addEventListener('beforeunload', function() {
                loadingBar.classList.add('active');
            });

            window.addEventListener('load', function() {
                setTimeout(() => {
                    loadingBar.classList.remove('active');
                }, 300);
            });

            // Close mobile sidebar
            function closeMobileSidebar() {
                sidebar.classList.remove('mobile-open');
                mobileOverlay?.classList.remove('show');
                document.body.style.overflow = '';
            }

            // Open mobile sidebar
            function openMobileSidebar() {
                sidebar.classList.add('mobile-open');
                mobileOverlay?.classList.add('show');
                document.body.style.overflow = 'hidden';
            }

            // Toggle sidebar
            sidebarToggle?.addEventListener('click', function (e) {
                e.stopPropagation();
                if (window.innerWidth <= 991.98) {
                    if (sidebar.classList.contains('mobile-open')) {
                        closeMobileSidebar();
                    } else {
                        openMobileSidebar();
                    }
                } else {
                    sidebar.classList.toggle('collapsed');
                    mainContent.classList.toggle('collapsed');

                    // Save preference
                    localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
                }
            });

            // Load saved preference
            if (window.innerWidth > 991.98) {
                const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
                if (isCollapsed) {
                    sidebar.classList.add('collapsed');
                    mainContent.classList.add('collapsed');
                }
            }

            // Close on overlay click
            mobileOverlay?.addEventListener('click', closeMobileSidebar);

            // Handle submenus
            document.querySelectorAll(".has-sub > a").forEach(item => {
                item.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    const parent = this.parentElement;
                    const wasOpen = parent.classList.contains("open");

                    // Close other open submenus
                    if (!wasOpen) {
                        document.querySelectorAll(".has-sub.open").forEach(el => {
                            if (el !== parent) {
                                el.classList.remove("open", "active");
                            }
                        });
                    }

                    parent.classList.toggle("open");
                    parent.classList.toggle("active", !wasOpen);
                });
            });

            // Handle window resize
            window.addEventListener('resize', function () {
                if (window.innerWidth > 991.98) {
                    closeMobileSidebar();
                    document.body.style.overflow = '';
                }
            });

            // Handle escape key
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && sidebar.classList.contains('mobile-open')) {
                    closeMobileSidebar();
                }
            });

            // Active link handling
            const currentPath = window.location.pathname.toLowerCase();
            document.querySelectorAll('.sidebar-menu a, .sidebar-bottom a').forEach(link => {
                const href = link.getAttribute('href')?.toLowerCase() || '';
                if (href && currentPath.includes(href) && href !== '#') {
                    link.classList.add('active');

                    // Open parent submenu if exists
                    const parentSub = link.closest('.has-sub');
                    if (parentSub) {
                        parentSub.classList.add('open', 'active');
                    }
                }
            });

            // Notification toast
            const notification = document.getElementById('notification');
            if (notification) {
                setTimeout(() => {
                    notification.style.opacity = '0';
                    setTimeout(() => notification.style.display = 'none', 500);
                }, 1500);
            }

            // Success toast with sound
            const toast = document.getElementById('successToast');
            if (toast) {
                try {
                    const ctx = new (window.AudioContext || window.webkitAudioContext)();
                    const now = ctx.currentTime;

                    function tone(freq, start, dur) {
                        const o = ctx.createOscillator();
                        const g = ctx.createGain();
                        o.type = 'sine';
                        o.frequency.value = freq;
                        o.connect(g);
                        g.connect(ctx.destination);
                        g.gain.setValueAtTime(0.0001, start);
                        g.gain.exponentialRampToValueAtTime(0.2, start + 0.01);
                        g.gain.exponentialRampToValueAtTime(0.0001, start + dur);
                        o.start(start);
                        o.stop(start + dur + 0.02);
                    }

                    tone(880, now + 0.00, 0.12);
                    tone(1047, now + 0.12, 0.14);

                    setTimeout(() => {
                        if (ctx && ctx.state !== 'closed') ctx.close();
                    }, 600);
                } catch (e) { }

                setTimeout(() => {
                    toast.classList.add('fade-out');
                    setTimeout(() => {
                        if (toast.parentNode) toast.parentNode.removeChild(toast);
                    }, 600);
                }, 1500);
            }
        });
    </script>

    <!-- End of Day Function -->
    <script>
        function openEndOfDay() {
            window.open('/EndOfDay', 'EndOfDay', 'width=900,height=800,scrollbars=yes,resizable=yes');
        }
    </script>

    @RenderSection("Scripts", required: false)
