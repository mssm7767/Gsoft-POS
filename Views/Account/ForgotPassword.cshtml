@model GSoftPosNew.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - POS System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" />

    <style>
        :root {
            --primary-color: #4361ee;
            --secondary-color: #3f37c9;
            --dark-color: #212529;
            --light-bg: #f8f9fa;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        .auth-card {
            width: 100%;
            max-width: 430px;
            background: #fff;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.12);
        }

        .auth-header {
            background: linear-gradient(to right, var(--primary-color), var(--secondary-color));
            color: #fff;
            text-align: center;
            padding: 32px 20px 24px;
        }

        .brand-icon {
            width: 72px;
            height: 72px;
            margin: 0 auto 15px;
            border-radius: 50%;
            background: rgba(255,255,255,0.18);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
        }

        .auth-header h3 {
            margin-bottom: 8px;
            font-weight: 700;
        }

        .auth-header p {
            margin-bottom: 0;
            opacity: 0.95;
            font-size: 14px;
        }

        .auth-body {
            padding: 30px;
        }

        .form-label {
            font-weight: 600;
            color: #374151;
        }

        .input-group-text {
            background: #eef2ff;
            color: var(--primary-color);
            border-right: 0;
        }

        .form-control {
            height: 48px;
            border-left: 0;
        }

            .form-control:focus {
                box-shadow: none;
                border-color: #ced4da;
            }

        .input-group:focus-within .input-group-text {
            border-color: var(--primary-color);
            background: #e0e7ff;
        }

        .btn-auth {
            height: 48px;
            font-weight: 600;
            border-radius: 10px;
            background: linear-gradient(to right, var(--primary-color), var(--secondary-color));
            border: none;
        }

            .btn-auth:hover {
                opacity: 0.95;
            }

        .back-link {
            color: var(--primary-color);
            font-weight: 600;
            text-decoration: none;
        }

            .back-link:hover {
                text-decoration: underline;
            }

        .validation-summary-errors ul {
            margin-bottom: 0;
            padding-left: 18px;
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="auth-header">
            <div class="brand-icon">
                <i class="fas fa-key"></i>
            </div>
            <h3>Forgot Password</h3>
            <p>Enter your email to receive password reset link</p>
        </div>

        <div class="auth-body">
            <form asp-action="ForgotPassword" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-success">@ViewBag.Message</div>
                }

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="fas fa-envelope"></i>
                        </span>
                        <input asp-for="Email" type="email" class="form-control" placeholder="Enter your email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-primary btn-auth">
                        <i class="fas fa-paper-plane me-2"></i>
                        Send Reset Link
                    </button>
                </div>

                <div class="text-center">
                    <a asp-action="Login" class="back-link">
                        <i class="fas fa-arrow-left me-1"></i>
                        Back to Login
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.querySelector('form');
            if (!form) return;

            form.addEventListener('submit', function (event) {
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            });
        });
    </script>
</body>
</html>