@using GSoftPosNew.ViewModels
@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Modern Dashboard Variables */
    :root {
        --primary: #4361ee;
        --primary-light: #4895ef;
        --primary-dark: #3f37c9;
        --secondary: #f72585;
        --success: #4cc9f0;
        --warning: #f8961e;
        --danger: #f94144;
        --dark: #1e293b;
        --darker: #0f172a;
        --light: #f8fafc;
        --gray: #94a3b8;
        --card-bg: rgba(255, 255, 255, 0.9);
        --card-border: rgba(255, 255, 255, 0.2);
        --glass-bg: rgba(255, 255, 255, 0.25);
        --glass-border: rgba(255, 255, 255, 0.18);
        --shadow-sm: 0 8px 20px rgba(0, 0, 0, 0.02);
        --shadow: 0 20px 40px rgba(0, 0, 0, 0.03);
        --shadow-lg: 0 30px 60px rgba(0, 0, 0, 0.05);
        --shadow-xl: 0 40px 80px rgba(0, 0, 0, 0.08);
        --blur: blur(20px);
        --gradient-1: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --gradient-2: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        --gradient-3: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        --gradient-4: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
        --gradient-5: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(145deg, #f1f5f9 0%, #eef2f6 100%);
        font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--dark);
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
    }

        /* Animated Background */
        body::before {
            content: '';
            position: fixed;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(67, 97, 238, 0.03) 0%, transparent 30%), radial-gradient(circle, rgba(247, 37, 133, 0.03) 0%, transparent 30%);
            animation: rotate 60s linear infinite;
            z-index: -1;
        }

    @@keyframes rotate {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    /* Floating Bubbles */
    .bubble {
        position: fixed;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(5px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        pointer-events: none;
        z-index: 0;
    }

    .bubble-1 {
        width: 300px;
        height: 300px;
        top: -150px;
        right: -150px;
        background: radial-gradient(circle, rgba(67, 97, 238, 0.1), rgba(247, 37, 133, 0.1));
        animation: float 20s ease-in-out infinite;
    }

    .bubble-2 {
        width: 400px;
        height: 400px;
        bottom: -200px;
        left: -200px;
        background: radial-gradient(circle, rgba(76, 201, 240, 0.1), rgba(248, 150, 30, 0.1));
        animation: float 25s ease-in-out infinite reverse;
    }

    .bubble-3 {
        width: 200px;
        height: 200px;
        top: 30%;
        left: 10%;
        background: radial-gradient(circle, rgba(249, 65, 68, 0.05), rgba(67, 97, 238, 0.05));
        animation: float 15s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% {
            transform: translate(0, 0) rotate(0deg);
        }

        33% {
            transform: translate(30px, -30px) rotate(120deg);
        }

        66% {
            transform: translate(-20px, 20px) rotate(240deg);
        }
    }

    /* Header Filter */
    .header-filter {
        background: var(--glass-bg);
        backdrop-filter: var(--blur);
        border: 1px solid var(--glass-border);
        border-radius: 30px;
        padding: 20px 25px;
        margin-bottom: 30px;
        box-shadow: var(--shadow-lg);
        position: relative;
        z-index: 10;
    }

        .header-filter form {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

    .date-input-group {
        display: flex;
        align-items: center;
        background: white;
        border-radius: 20px;
        padding: 4px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .date-label {
        padding: 8px 16px;
        background: var(--gradient-1);
        color: white;
        border-radius: 16px;
        font-weight: 600;
        font-size: 13px;
        margin-right: 5px;
    }

    .date-input {
        border: none;
        padding: 8px 15px;
        border-radius: 16px;
        font-size: 13px;
        color: var(--dark);
        background: transparent;
    }

        .date-input:focus {
            outline: none;
        }

    .btn-filter {
        background: var(--gradient-1);
        border: none;
        padding: 10px 25px;
        border-radius: 20px;
        color: white;
        font-weight: 600;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px rgba(102, 126, 234, 0.2);
    }

        .btn-filter:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(102, 126, 234, 0.3);
        }

    .btn-reset {
        background: white;
        border: 1px solid rgba(0, 0, 0, 0.05);
        padding: 10px 20px;
        border-radius: 20px;
        color: var(--gray);
        font-weight: 600;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-reset:hover {
            background: #f8fafc;
            transform: translateY(-2px);
        }

    .current-time {
        background: white;
        border-radius: 30px;
        padding: 10px 25px;
        display: flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(0, 0, 0, 0.03);
    }

        .current-time i {
            color: var(--primary);
            font-size: 18px;
        }

        .current-time span {
            font-weight: 600;
            color: var(--dark);
        }

    .license-badge {
        background: linear-gradient(135deg, #fff3cd, #fff8e7);
        border-radius: 30px;
        padding: 8px 20px;
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #ffeeba;
        color: #856404;
        font-weight: 600;
    }

        .license-badge i {
            color: #f8961e;
        }

    /* Summary Cards */
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
        margin-bottom: 30px;
    }

    .summary-card {
        background: var(--card-bg);
        backdrop-filter: var(--blur);
        border: 1px solid var(--card-border);
        border-radius: 30px;
        padding: 25px;
        display: flex;
        align-items: center;
        gap: 20px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

        .summary-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--gradient-1);
            transform: scaleX(0);
            transition: transform 0.4s ease;
        }

        .summary-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: var(--shadow-xl);
        }

            .summary-card:hover::before {
                transform: scaleX(1);
            }

    .summary-icon {
        width: 70px;
        height: 70px;
        border-radius: 25px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        transition: all 0.4s ease;
        position: relative;
        z-index: 2;
    }

    .summary-card:hover .summary-icon {
        transform: scale(1.1) rotate(5deg);
    }

    .summary-icon.gradient-1 {
        background: var(--gradient-1);
        color: white;
    }

    .summary-icon.gradient-2 {
        background: var(--gradient-2);
        color: white;
    }

    .summary-icon.gradient-3 {
        background: var(--gradient-3);
        color: white;
    }

    .summary-icon.gradient-4 {
        background: var(--gradient-4);
        color: white;
    }

    .summary-content {
        flex: 1;
    }

    .summary-label {
        color: var(--gray);
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 5px;
    }

    .summary-value {
        font-size: 32px;
        font-weight: 800;
        background: linear-gradient(135deg, var(--dark), var(--primary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1.2;
    }

    /* Chart Cards */
    .chart-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 25px;
        margin-bottom: 30px;
    }

    .chart-card {
        background: var(--card-bg);
        backdrop-filter: var(--blur);
        border: 1px solid var(--card-border);
        border-radius: 30px;
        padding: 25px;
        box-shadow: var(--shadow);
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
    }

        .chart-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-xl);
        }

    .chart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .chart-title {
        font-size: 20px;
        font-weight: 700;
        color: var(--dark);
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .chart-title i {
            background: var(--gradient-1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .chart-badge {
        background: rgba(67, 97, 238, 0.1);
        padding: 5px 15px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 600;
        color: var(--primary);
    }

    .chart-container {
        position: relative;
        width: 100%;
        height: 300px;
    }

    /* Most Sales Container */
    .most-sales-container {
        position: relative;
        width: 100%;
        height: 300px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .most-sales-wrap {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 2;
    }

    /* Animated Balls */
    .ball-container {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        pointer-events: none;
    }

    .sales-ball {
        position: absolute;
        border-radius: 50%;
        filter: blur(30px);
        opacity: 0.5;
        animation: floatBall 15s ease-in-out infinite;
    }

    .ball-1 {
        width: 150px;
        height: 150px;
        background: radial-gradient(circle, #667eea, #764ba2);
        top: 10%;
        left: 10%;
        animation-delay: 0s;
    }

    .ball-2 {
        width: 120px;
        height: 120px;
        background: radial-gradient(circle, #f093fb, #f5576c);
        bottom: 10%;
        right: 10%;
        animation-delay: 2s;
    }

    .ball-3 {
        width: 100px;
        height: 100px;
        background: radial-gradient(circle, #4facfe, #00f2fe);
        top: 30%;
        right: 20%;
        animation-delay: 4s;
    }

    .ball-4 {
        width: 80px;
        height: 80px;
        background: radial-gradient(circle, #43e97b, #38f9d7);
        bottom: 30%;
        left: 20%;
        animation-delay: 6s;
    }

    @@keyframes floatBall {
        0%, 100% {
            transform: translate(0, 0) scale(1);
        }

        25% {
            transform: translate(20px, -20px) scale(1.1);
        }

        50% {
            transform: translate(-15px, 15px) scale(0.9);
        }

        75% {
            transform: translate(-20px, -15px) scale(1.05);
        }
    }

    /* Quick Actions */
    .quick-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 25px;
        margin-bottom: 30px;
    }

    .quick-card {
        background: var(--card-bg);
        backdrop-filter: var(--blur);
        border: 1px solid var(--card-border);
        border-radius: 30px;
        padding: 30px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

        .quick-card::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.4s ease;
            pointer-events: none;
        }

        .quick-card:hover::after {
            opacity: 1;
        }

        .quick-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: var(--shadow-xl);
        }

    .quick-icon {
        width: 100px;
        height: 100px;
        border-radius: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        margin-bottom: 20px;
        transition: all 0.4s ease;
        color: white;
        position: relative;
        z-index: 2;
    }

    .quick-card:hover .quick-icon {
        transform: scale(1.1) rotate(360deg);
    }

    .quick-icon.gradient-1 {
        background: var(--gradient-1);
    }

    .quick-icon.gradient-2 {
        background: var(--gradient-2);
    }

    .quick-icon.gradient-3 {
        background: var(--gradient-3);
    }

    .quick-icon.gradient-4 {
        background: var(--gradient-4);
    }

    .quick-icon.gradient-5 {
        background: var(--gradient-5);
    }

    .quick-title {
        font-size: 20px;
        font-weight: 700;
        color: var(--dark);
        margin-bottom: 10px;
        position: relative;
        z-index: 2;
    }

    .quick-number {
        font-size: 36px;
        font-weight: 800;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 20px;
        position: relative;
        z-index: 2;
    }

    .quick-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
        position: relative;
        z-index: 2;
    }

    .action-btn {
        padding: 12px 24px;
        border: none;
        border-radius: 20px;
        font-weight: 600;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
    }

        .action-btn.primary {
            background: var(--gradient-1);
            color: white;
        }

        .action-btn.success {
            background: var(--gradient-4);
            color: white;
        }

        .action-btn.warning {
            background: var(--gradient-5);
            color: white;
        }

        .action-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
        }

    /* Stats Cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 25px;
    }

    .stat-card {
        background: var(--card-bg);
        backdrop-filter: var(--blur);
        border: 1px solid var(--card-border);
        border-radius: 30px;
        padding: 25px;
        display: flex;
        align-items: center;
        gap: 20px;
        transition: all 0.4s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-xl);
        }

    .stat-icon {
        width: 70px;
        height: 70px;
        border-radius: 25px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: white;
    }

        .stat-icon.warning {
            background: linear-gradient(135deg, #f8961e, #f94144);
        }

        .stat-icon.success {
            background: linear-gradient(135deg, #4cc9f0, #43e97b);
        }

    .stat-content {
        flex: 1;
    }

    .stat-label {
        color: var(--gray);
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 5px;
    }

    .stat-value {
        font-size: 28px;
        font-weight: 800;
        color: var(--dark);
    }

    /* Product Table */
    .table-section {
        margin-top: 30px;
    }

    .table-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .table-title {
        font-size: 20px;
        font-weight: 700;
        color: var(--dark);
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .table-title i {
            background: var(--gradient-1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .table-container {
        background: var(--card-bg);
        backdrop-filter: var(--blur);
        border: 1px solid var(--card-border);
        border-radius: 30px;
        padding: 20px;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

    .modern-table {
        width: 100%;
        border-collapse: collapse;
    }

        .modern-table th {
            text-align: left;
            padding: 16px 20px;
            background: linear-gradient(135deg, #667eea10, #764ba210);
            font-weight: 700;
            color: var(--primary-dark);
            font-size: 14px;
            border-bottom: 2px solid rgba(102, 126, 234, 0.2);
        }

        .modern-table td {
            padding: 16px 20px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.03);
            color: var(--dark);
            font-size: 14px;
        }

        .modern-table tr:hover td {
            background: linear-gradient(135deg, #667eea05, #764ba205);
        }

    .table-actions {
        display: flex;
        gap: 10px;
    }

    .table-btn {
        width: 35px;
        height: 35px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .table-btn.edit {
            background: linear-gradient(135deg, #4cc9f0, #4895ef);
        }

        .table-btn.delete {
            background: linear-gradient(135deg, #f94144, #f8961e);
        }

        .table-btn:hover {
            transform: scale(1.1);
        }

    /* Spin Animation */
    @@keyframes spin-once {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .spin-on-load {
        animation: spin-once 1s ease-out forwards;
    }

    /* Responsive */
    @@media (max-width: 1200px) {
        .summary-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .chart-grid {
            grid-template-columns: 1fr;
        }

        .quick-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .summary-grid {
            grid-template-columns: 1fr;
        }

        .quick-grid {
            grid-template-columns: 1fr;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .header-filter form {
            flex-direction: column;
            align-items: stretch;
        }

        .date-input-group {
            width: 100%;
        }
    }
</style>

<!-- Floating Background Bubbles -->
<div class="bubble bubble-1"></div>
<div class="bubble bubble-2"></div>
<div class="bubble bubble-3"></div>

<div class="container-fluid p-4">
    <!-- Header with Filter -->
    <div class="header-filter">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <form method="get" asp-action="Index" class="d-flex align-items-center gap-2 flex-wrap">
                <div class="date-input-group">
                    <span class="date-label">From</span>
                    <input type="date" name="fromDate" class="date-input" value="@ViewBag.FromDate" />
                </div>

                <div class="date-input-group">
                    <span class="date-label">To</span>
                    <input type="date" name="toDate" class="date-input" value="@ViewBag.ToDate" />
                </div>

                <button type="submit" class="btn-filter">
                    <i class="fas fa-filter"></i> Filter
                </button>

                <a asp-action="Index" class="btn-reset">
                    <i class="fas fa-sync-alt"></i> Reset
                </a>
            </form>

            <div class="d-flex align-items-center gap-3">
                <div class="current-time">
                    <i class="fas fa-clock"></i>
                    <span id="currentDateTime"></span>
                </div>

                <div class="license-badge">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span>License: @ViewBag.DaysLeft days left</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="summary-grid">
        <div class="summary-card">
            <div class="summary-icon gradient-1">
                <i class="fas fa-shopping-cart"></i>
            </div>
            <div class="summary-content">
                <div class="summary-label">Total Sales</div>
                <div class="summary-value">@Model.TotalSales.ToString("N2")</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon gradient-2">
                <i class="fas fa-box-open"></i>
            </div>
            <div class="summary-content">
                <div class="summary-label">Total Purchases</div>
                <div class="summary-value">@Model.TotalPurchases.ToString("N2")</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon gradient-3">
                <i class="fas fa-credit-card"></i>
            </div>
            <div class="summary-content">
                <div class="summary-label">Total Paid</div>
                <div class="summary-value">@Model.TotalRevenuesOrPayments.ToString("N2")</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon gradient-4">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="summary-content">
                <div class="summary-label">Profits</div>
                <div class="summary-value">@Model.TotalProfit.ToString("N2")</div>
            </div>
        </div>
    </div>

    <!-- Charts -->
    <div class="chart-grid">
        <!-- Sales Chart -->
        <div class="chart-card">
            <div class="chart-header">
                <div class="chart-title">
                    <i class="fas fa-chart-line"></i>
                    Sales Overview
                </div>
                <span class="chart-badge">Monthly</span>
            </div>
            <div class="chart-container">
                <canvas id="salesChart"></canvas>
            </div>
        </div>

        <!-- Most Sales Chart -->
        <div class="chart-card">
            <div class="chart-header">
                <div class="chart-title">
                    <i class="fas fa-chart-pie"></i>
                    Top Products
                </div>
                <span class="chart-badge">Share</span>
            </div>

            <div class="most-sales-container">
                <!-- Animated Balls -->
                <div class="ball-container">
                    <div class="sales-ball ball-1"></div>
                    <div class="sales-ball ball-2"></div>
                    <div class="sales-ball ball-3"></div>
                    <div class="sales-ball ball-4"></div>
                </div>

                <div class="most-sales-wrap spin-on-load" id="mostSalesWrap">
                    <canvas id="mostSalesChart" width="280" height="280"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="quick-grid">
        <div class="quick-card">
            <div class="quick-icon gradient-1">
                <i class="fas fa-box"></i>
            </div>
            <div class="quick-title">Quick Actions</div>
            <div class="quick-actions">
                <a href="@Url.Action("Add", "Item")" class="action-btn primary">
                    <i class="fas fa-plus"></i> Add Item
                </a>
                <a href="@Url.Action("POS", "Sales")" class="action-btn success">
                    <i class="fas fa-shopping-cart"></i> POS
                </a>
                <a href="@Url.Action("Create", "Purchase")" class="action-btn warning">
                    <i class="fas fa-truck"></i> Purchase
                </a>
            </div>
        </div>

        <div class="quick-card">
            <div class="quick-icon gradient-2">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="quick-title">Expiry Items</div>
            <div class="quick-number">@Model.TotalExpiryItems</div>
            <div class="quick-actions">
                <a href="@Url.Action("Index", "Item")" class="action-btn warning">
                    <i class="fas fa-eye"></i> View All
                </a>
            </div>
        </div>

        <div class="quick-card">
            <div class="quick-icon gradient-3">
                <i class="fas fa-box-open"></i>
            </div>
            <div class="quick-title">Low Stock</div>
            <div class="quick-number">@Model.TotalLowStockItems</div>
            <div class="quick-actions">
                <a href="@Url.Action("Index", "Item")" class="action-btn success">
                    <i class="fas fa-eye"></i> View All
                </a>
            </div>
        </div>
    </div>

    <!-- Product Table -->
    <div class="table-section">
        <div class="table-header">
            <div class="table-title">
                <i class="fas fa-table"></i>
                Product Inventory
            </div>
            <a href="@Url.Action("Add", "Item")" class="action-btn primary">
                <i class="fas fa-plus"></i> Add New Product
            </a>
        </div>

        <div class="table-container">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Product Name</th>
                        <th>Code</th>
                        <th>Price</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ItemsList)
                    {
                        <tr>
                            <td>#@item.Id.ToString("000")</td>
                            <td>@item.ItemName</td>
                            <td>@item.ItemCode</td>
                            <td>@item.SalePrice.ToString("N2")</td>
                            <td>
                                <div class="table-actions">
                                    <a asp-controller="Item" asp-action="Edit" asp-route-id="@item.Id" class="table-btn edit" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-controller="Item" asp-action="Delete" asp-route-id="@item.Id" class="table-btn delete" title="Delete"
                                       onclick="return confirm('Are you sure you want to delete this item?');">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (Model.ItemsList == null || !Model.ItemsList.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5" style="color: var(--gray);">
                                <i class="fas fa-box-open mb-3" style="font-size: 48px;"></i>
                                <br />
                                No products found
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="~/lib/chart/chart.js"></script>

<script>
    // Live DateTime
    function updateDateTime() {
        const now = new Date();
        const options = {
            weekday: 'short',
            year: 'numeric',
            month: 'short',
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit',
            hour12: true
        };
        document.getElementById('currentDateTime').textContent = now.toLocaleString('en-US', options);
    }

    updateDateTime();
    setInterval(updateDateTime, 1000);

    // Sales Chart
    const salesCtx = document.getElementById('salesChart').getContext('2d');
    new Chart(salesCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(Json.Serialize(Model.SalesMonths)),
            datasets: [{
                label: 'Sales',
                data: @Html.Raw(Json.Serialize(Model.SalesData)),
                borderColor: '#4361ee',
                backgroundColor: 'rgba(67, 97, 238, 0.05)',
                borderWidth: 3,
                pointBackgroundColor: '#4361ee',
                pointBorderColor: '#ffffff',
                pointBorderWidth: 2,
                pointRadius: 6,
                pointHoverRadius: 8,
                tension: 0.4,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    backgroundColor: 'rgba(255, 255, 255, 0.95)',
                    titleColor: '#1e293b',
                    bodyColor: '#1e293b',
                    borderColor: '#e2e8f0',
                    borderWidth: 1,
                    cornerRadius: 16,
                    padding: 12
                }
            },
            scales: {
                x: {
                    grid: {
                        display: false
                    },
                    ticks: {
                        color: '#94a3b8'
                    }
                },
                y: {
                    grid: {
                        color: '#f1f5f9'
                    },
                    ticks: {
                        color: '#94a3b8'
                    }
                }
            }
        }
    });

    // Most Sales Chart
    const mostSalesCtx = document.getElementById('mostSalesChart').getContext('2d');
    new Chart(mostSalesCtx, {
        type: 'doughnut',
        data: {
            labels: @Html.Raw(Json.Serialize(Model.TopProducts)),
            datasets: [{
                data: @Html.Raw(Json.Serialize(Model.TopProductSales)),
                backgroundColor: ['#4361ee', '#f72585', '#4cc9f0', '#f8961e', '#43e97b'],
                borderWidth: 0,
                hoverOffset: 15
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '65%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        color: '#94a3b8',
                        font: {
                            size: 11
                        },
                        padding: 15,
                        usePointStyle: true,
                        pointStyle: 'circle'
                    }
                },
                tooltip: {
                    backgroundColor: 'rgba(255, 255, 255, 0.95)',
                    titleColor: '#1e293b',
                    bodyColor: '#1e293b',
                    borderColor: '#e2e8f0',
                    borderWidth: 1,
                    cornerRadius: 16
                }
            }
        }
    });

    // Spin animation
    function spinMostSales() {
        const wrap = document.getElementById('mostSalesWrap');
        if (!wrap) return;
        wrap.classList.remove('spin-on-load');
        void wrap.offsetWidth;
        wrap.classList.add('spin-on-load');
    }

    setInterval(spinMostSales, 10000);
</script>